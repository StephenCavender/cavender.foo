---
import { type CollectionEntry, getCollection, render } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "@layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const games = await getCollection("games");
  return games.map((game) => ({
    params: { slug: game.id },
    props: game,
  }));
}
type Props = CollectionEntry<"games">;

const game = Astro.props;
const { Content } = await render(game);
---

<BaseLayout>
  <article class="game">
    <header>
      {
        game.data.cover && (
          <div class="game-cover">
            <Image
              src={game.data.cover}
              alt={`Cover for ${game.data.title}`}
            />
          </div>
        )
      }

      <h1>{game.data.title}</h1>

      <p class="game-status">
        <span class="status-badge status-{game.data.status}"
          >{game.data.status}</span
        >
      </p>

      {
        game.data.rating && (
          <div class="game-rating">
            <span class="stars">
              {"★".repeat(game.data.rating)}
              {"☆".repeat(5 - game.data.rating)}
            </span>
            <span class="rating-text">{game.data.rating} / 5</span>
          </div>
        )
      }

      {
        game.data.developer && (
          <p class="meta-line">
            <span class="meta-label">Developer:</span> {game.data.developer}
          </p>
        )
      }
      {
        game.data.publisher && (
          <p class="meta-line">
            <span class="meta-label">Publisher:</span> {game.data.publisher}
          </p>
        )
      }
      {
        game.data.platform && game.data.platform.length > 0 && (
          <p class="meta-line">
            <span class="meta-label">Platform:</span>{" "}
            {game.data.platform.join(", ")}
          </p>
        )
      }
      {
        game.data.releaseDate && (
          <p class="meta-line">
            <span class="meta-label">Released:</span>{" "}
            {game.data.releaseDate.toLocaleDateString()}
          </p>
        )
      }
      {
        game.data.playDate && (
          <p class="meta-line">
            <span class="meta-label">Played:</span>{" "}
            {game.data.playDate.toLocaleDateString()}
          </p>
        )
      }

      {
        game.data.steamLink && (
          <p class="meta-line">
            <span class="meta-label">Steam:</span>{" "}
            <a
              href={game.data.steamLink}
              target="_blank"
              rel="noopener noreferrer"
            >
              View on Steam ↗
            </a>
          </p>
        )
      }
    </header>

    <div class="game-content prose">
      <Content />
    </div>

    {
      game.data.tags && game.data.tags.length > 0 && (
        <div class="tags">
          {game.data.tags.map((tag) => (
            <a href={`/games/tags/${tag}/`}>#{tag}</a>
          ))}
        </div>
      )
    }

    <a href="/games">Back to Games</a>
  </article>
</BaseLayout>

<style>
  .game {
    max-width: 800px;
    margin: 0 auto;
  }

  header {
    margin-bottom: 2rem;
  }

  .game-cover {
    float: right;
    margin: 0 0 1.5rem 2rem;
  }

  .game-cover img {
    max-width: 160px;
    height: auto;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.15);
    border-radius: 8px;
    display: block;
  }

  h1 {
    margin-bottom: 0.5rem;
    line-height: 1.2;
  }

  .game-status {
    margin-bottom: 0.75rem;
  }

  .status-badge {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    border-radius: 4px;
    font-size: 0.85rem;
    font-weight: bold;
    text-transform: uppercase;
    line-height: 1;
  }

  .status-playing {
    background-color: #4caf50;
    color: white;
  }

  .status-played {
    background-color: #2196f3;
    color: white;
  }

  .status-unplayed {
    background-color: #9e9e9e;
    color: white;
  }

  .game-rating {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
    font-size: 1rem;
  }

  .stars {
    color: #f5a623;
    font-size: 1.2rem;
  }

  .rating-text {
    color: var(--text-secondary);
  }

  .meta-line {
    margin: 0.35rem 0;
    font-size: 0.95rem;
    color: var(--text-secondary);
  }

  .meta-label {
    font-weight: bold;
    color: var(--text-primary);
  }

  .meta-line a {
    color: var(--text-link);
    text-decoration: none;
  }

  .meta-line a:hover {
    text-decoration: underline;
  }

  .game-content {
    clear: both;
    line-height: 1.6;
  }

  .tags {
    display: flex;
    justify-content: center;
    column-gap: 0.75em;
    flex-wrap: wrap;
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
  }

  .tags a {
    font-weight: normal;
    text-decoration: none;
  }

  .tags a:hover {
    color: var(--text-secondary);
  }

  @media (max-width: 600px) {
    .game-cover {
      float: none;
      margin: 0 auto 1.5rem auto;
      text-align: center;
    }
  }
</style>
