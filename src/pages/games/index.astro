---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "@layouts/BaseLayout.astro";

const gameCollection = await getCollection("games");
const games = gameCollection.sort((a, b) => {
  const statusOrder = { playing: 0, unplayed: 1, played: 2 };
  const aStatus = statusOrder[a.data.status] ?? 3;
  const bStatus = statusOrder[b.data.status] ?? 3;

  if (aStatus !== bStatus) {
    return aStatus - bStatus;
  }

  return a.data.title.localeCompare(b.data.title);
});

// Count by status
const statusCounts = {
  playing: games.filter((g) => g.data.status === "playing").length,
  played: games.filter((g) => g.data.status === "played").length,
  unplayed: games.filter((g) => g.data.status === "unplayed").length,
};
---

<BaseLayout>
  <div class="page-header">
    <h2>Video Games</h2>
    <a href="/games/tags/">Browse by Tags</a>
  </div>
  <div class="status-summary">
    <span class="status-count">
      <span class="status-badge status-playing">Playing</span>
      ({statusCounts.playing})
    </span>
    <span class="status-count">
      <span class="status-badge status-played">Played</span>
      ({statusCounts.played})
    </span>
    <span class="status-count">
      <span class="status-badge status-unplayed">Backlog</span>
      ({statusCounts.unplayed})
    </span>
  </div>
  <section>
    <div class="game-grid">
      {
        games.map((game) => (
          <a href={`/games/${game.id}/`} class="game-card">
            <div class="cover-wrap">
              {game.data.cover ? (
                <Image
                  src={game.data.cover}
                  alt={game.data.title}
                  class="cover-img"
                  loading="lazy"
                />
              ) : (
                <div class="cover-placeholder">
                  <span class="placeholder-title">{game.data.title}</span>
                </div>
              )}
              <span class={`status-badge status-${game.data.status}`}>
                {game.data.status === "unplayed" ? "backlog" : game.data.status}
              </span>
            </div>
            <div class="game-meta">
              <span class="game-title">{game.data.title}</span>
            </div>
          </a>
        ))
      }
    </div>
  </section>
</BaseLayout>

<style>
  .game-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(150px, 1fr));
    gap: 1.5rem;
  }

  .game-card {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    text-decoration: none;
    color: var(--text-primary);
  }

  .game-card:hover .cover-wrap {
    transform: scale(1.03);
  }

  .game-card:hover .game-title {
    color: var(--text-secondary);
  }

  .cover-wrap {
    position: relative;
    aspect-ratio: 2 / 3;
    border-radius: 4px;
    overflow: hidden;
    background: var(--bg-secondary);
    transition: transform 0.2s ease;
  }

  .cover-wrap .cover-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 4px;
    display: block;
  }

  .cover-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 0.75rem;
    gap: 0.5rem;
    background: var(--bg-secondary);
  }

  .placeholder-title {
    font-size: 0.8rem;
    font-weight: bold;
    text-align: center;
    line-height: 1.3;
    color: var(--text-primary);
  }

  .cover-wrap .status-badge {
    position: absolute;
    top: 0.4rem;
    left: 0.4rem;
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
    font-size: 0.65rem;
    font-weight: bold;
    text-transform: uppercase;
    line-height: 1;
  }

  .status-summary .status-badge {
    padding: 0.15rem 0.4rem;
    border-radius: 3px;
    font-size: 0.65rem;
    font-weight: bold;
    text-transform: uppercase;
    line-height: 1;
  }

  .status-playing {
    background-color: var(--status-active);
    color: white;
  }

  .status-played {
    background-color: var(--status-done);
    color: white;
  }

  .status-unplayed {
    background-color: var(--status-neutral);
    color: white;
  }

  .game-meta {
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .game-title {
    font-size: 1.2rem;
    font-weight: bold;
    line-height: 1.3;
    transition: color 0.15s ease;
  }

  .status-summary {
    display: flex;
    gap: 1.5rem;
    margin-bottom: 2rem;
    flex-wrap: wrap;
  }

  .status-count {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--text-secondary);
  }

  @media (max-width: 600px) {
    .status-summary {
      justify-content: center;
    }
  }
</style>
