---
import { type CollectionEntry, getCollection, render } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";

export async function getStaticPaths() {
  const books = await getCollection("books");
  return books.map((book) => ({
    params: { slug: book.id },
    props: book,
  }));
}
type Props = CollectionEntry<"books">;

const book = Astro.props;
const { Content } = await render(book);
---

<BaseLayout>
  <article class="book">
    <header>
      {
        book.data.cover && (
          <div class="book-cover">
            <img
              src={book.data.cover.src}
              alt={`Cover for ${book.data.title}`}
            />
          </div>
        )
      }

      <h1>{book.data.title}</h1>
      <p class="book-author">by <strong>{book.data.author}</strong></p>

      {
        book.data.readDate && (
          <p class="read-date">
            Read {book.data.readDate.toLocaleDateString()}
          </p>
        )
      }

      {book.data.isbn && <p class="book-isbn">ISBN: {book.data.isbn}</p>}
    </header>

    <div class="book-content prose">
      <Content />
    </div>

    {
      book.data.tags && book.data.tags.length > 0 && (
        <div class="tags">
          {book.data.tags.map((tag) => (
            <a href={`/books/tags/${tag}/`}>#{tag}</a>
          ))}
        </div>
      )
    }

    <a href="/books">Back to Books</a>
  </article>
</BaseLayout>

<style>
  .book {
    max-width: 800px;
    margin: 0 auto;
  }

  header {
    margin-bottom: 2rem;
  }

  .book-cover {
    float: right;
    margin: 0 0 1.5rem 2rem;
  }

  .book-cover img {
    max-width: 160px;
    height: auto;
    box-shadow: 0 4px 10px rgba(0, 0, 0, 0.15);
    border-radius: 8px;
    display: block;
  }

  h1 {
    margin-bottom: 0.5rem;
    line-height: 1.2;
  }

  .book-author {
    font-size: 1.2rem;
    margin-bottom: 0.75rem;
  }

  .read-date,
  .book-isbn {
    font-size: 0.95rem;
    margin: 0.35rem 0;
    color: var(--text-secondary);
  }

  .book-content {
    clear: both;
    line-height: 1.6;
  }

  .tags {
    display: flex;
    justify-content: center;
    column-gap: 0.75em;
    flex-wrap: wrap;
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--line);
  }

  .tags a {
    font-weight: normal;
    text-decoration: none;
  }

  .tags a:hover {
    color: var(--text-secondary);
  }

  @media (max-width: 600px) {
    .book-cover {
      float: none;
      margin: 0 auto 1.5rem auto;
      text-align: center;
    }
  }
</style>
