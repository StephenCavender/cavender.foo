---
import { getCollection } from "astro:content";
import BaseLayout from "@layouts/BaseLayout.astro";

// Get the environment to determine whether to show drafts
const isDev = import.meta.env.DEV;

// Filter books based on environment and exclude template
const allBooks = await getCollection("books");
const books = allBooks
  .filter((book) => {
    // Exclude template file and respect draft status
    return !book.id.startsWith("_template") && (isDev || !book.data.draft);
  })
  .sort((a, b) => {
    // Sort by status first (reading > read > unread), then by readDate/title
    const statusOrder = { reading: 0, read: 1, unread: 2 };
    const aStatus = statusOrder[a.data.status] || 3;
    const bStatus = statusOrder[b.data.status] || 3;

    if (aStatus !== bStatus) {
      return aStatus - bStatus;
    }

    // For read books, sort by readDate (newest first)
    if (a.data.status === "read" && b.data.status === "read") {
      const aDate = a.data.readDate || new Date(0);
      const bDate = b.data.readDate || new Date(0);
      return bDate.valueOf() - aDate.valueOf();
    }

    // Otherwise sort by title
    return a.data.title.localeCompare(b.data.title);
  });

// Get template if in dev mode
const template = isDev
  ? (
      await getCollection("books", (book) => book.id.startsWith("_template"))
    ).at(0)
  : null;
---

<BaseLayout>
  <h2>My Bookshelf</h2>
  <div
    style="display: flex; justify-content: space-between; align-items: center;"
  >
    <div></div>
    <a href="/books/tags/">Browse by Tags</a>
  </div>
  <section>
    {
      isDev && template && (
        <div class="template-container">
          <h3>Book Template</h3>
          <p>This template is only visible in development mode</p>
          <a href={`/books/${template.id}/`} class="template-link">
            View Template
          </a>
        </div>
      )
    }
    <ul>
      {
        books.map((book) => (
          <li>
            <span class="status-badge status-{book.data.status}">
              {book.data.status}
            </span>
            <a href={`/books/${book.id}/`}>
              {book.data.title} by {book.data.author}
              {book.data.draft && <span class="draft-indicator">[DRAFT]</span>}
            </a>
          </li>
        ))
      }
    </ul>
  </section>
</BaseLayout>
<style>
  li {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .status-badge {
    flex: 0 0 80px;
    min-width: 80px;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: bold;
    text-align: center;
    text-transform: uppercase;
  }
  .status-reading {
    background-color: #4caf50;
    color: white;
  }
  .status-read {
    background-color: #2196f3;
    color: white;
  }
  .status-unread {
    background-color: #9e9e9e;
    color: white;
  }
  .draft-indicator {
    margin-left: 0.5rem;
    color: #ff6b6b;
    font-size: 0.85em;
    font-weight: bold;
  }
  .template-container {
    background-color: #4a3f7d;
    border: 2px dashed #8269ff;
    padding: 1rem;
    margin-bottom: 2rem;
    border-radius: 8px;
  }
  .template-link {
    display: inline-block;
    background-color: #8269ff;
    color: white;
    padding: 0.5rem 1rem;
    border-radius: 4px;
    text-decoration: none;
    margin-top: 0.5rem;
  }
  .template-link:hover {
    background-color: #6a4dff;
  }
</style>
